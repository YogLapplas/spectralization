{
  "multipart": [
    {
      "apply": {
        "model": "spectralization:block/holographic_storage_shell"
      }
    },
    {
      "when": {
        "error": "false"
      },
      "apply": {
        "model": "spectralization:block/holographic_storage_main_core"
      }
    },
    {
      "when": {
        "error": "true"
      },
      "apply": {
        "model": "spectralization:block/holographic_storage_main_core_error"
      }
    }
  ]
}
